{
  "name": "harness-core",
  "version": "0.0.1",
  "private": true,
  "description": "Minimal universal multi-agent harness core",
  "type": "module",
  "bin": {
    "harness": "./bin/harness.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node ./dist/cli/index.js",
    "dev": "node --enable-source-maps ./dist/cli/index.js",
    "smoke:assignment-fence": "node ./scripts/assignment-fence-smoke.mjs",
    "smoke:auth": "node ./scripts/auth-smoke.mjs",
    "smoke:multi-worker": "node ./scripts/multi-worker-smoke.mjs",
    "smoke:restart-reconcile": "node ./scripts/restart-reconcile-smoke.mjs",
    "smoke:cancel-replay": "node ./scripts/cancel-replay-smoke.mjs",
    "smoke:gate-fix": "node ./scripts/gate-fix-smoke.mjs",
    "smoke:session-config": "node ./scripts/session-config-smoke.mjs",
    "smoke:operator-happy-path": "node ./scripts/operator-happy-path-smoke.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
